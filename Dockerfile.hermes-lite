FROM docker/sandbox-templates:shell

ARG HERMES_REF=main

COPY docker/hermes-lite-entrypoint.sh /usr/local/bin/hermes-lite-entrypoint

USER root

RUN apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        ffmpeg \
        git \
        openssh-client \
    && rm -rf /var/lib/apt/lists/* \
    && mkdir -p /opt/data /home/agent/.local/bin \
    && chown -R agent:agent /opt/data /home/agent/.local

USER agent
ENV HOME=/home/agent
ENV HERMES_HOME=/opt/data
ENV PATH="/home/agent/.local/bin:${PATH}"
WORKDIR /home/agent

RUN curl -fsSL "https://raw.githubusercontent.com/NousResearch/hermes-agent/${HERMES_REF}/scripts/install.sh" \
    | bash -s -- --skip-setup --branch "${HERMES_REF}" --dir /home/agent/hermes-agent

RUN HERMES_HOME=/opt/data HOME=/home/agent hermes skills list >/dev/null

USER root
RUN chmod 755 /usr/local/bin/hermes-lite-entrypoint

USER agent
WORKDIR /workspace
VOLUME ["/opt/data"]
ENTRYPOINT ["/usr/local/bin/hermes-lite-entrypoint"]
CMD ["hermes", "gateway", "run"]
